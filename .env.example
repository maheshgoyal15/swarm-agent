# ── State DB connection (where evo_state schema lives) ──────────────────────
# This is the PostgreSQL / AlloyDB instance EvoAgent writes its own state into.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# ── Target schema to analyze and optimize ───────────────────────────────────
# The schema EvoAgent's agents will read, profile, and generate recommendations for.
TARGET_SCHEMA=public

# ── Gemini / Vertex AI (required for agent LLM calls) ───────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here
